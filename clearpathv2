// PAGE: CHECKLIST (WITH AI EXPLAINER)
// ============================================================================
function Checklist() {
  const [loanType, setLoanType] = useState("");
  const [entity, setEntity] = useState("");
  
  // AI Explainer State
  const [explainingItem, setExplainingItem] = useState(null);
  const [explanationText, setExplanationText] = useState("");
  const [isExplaining, setIsExplaining] = useState(false);
  
  // Interaction State: Make checklist functional
  const [checkedItems, setCheckedItems] = useState(new Set());

  const items = (loanType && entity) ? [
    "SBA Form 1919 — Borrower Information Form",
    "SBA Form 413 — Personal Financial Statement",
    "3 years federal business tax returns",
    "YTD Profit & Loss and Balance Sheet",
    "Business debt schedule",
    "Government-issued photo ID",
    entity === "LLC" ? "Operating Agreement" : "Articles of Incorporation",
    loanType === "real_estate" ? "Commercial Real Estate Purchase Contract" : "Detailed Use of Proceeds"
  ] : [];

  const handleExplain = async (item) => {
    setExplainingItem(item);
    setIsExplaining(true);
    setExplanationText("");
    
    try {
      const prompt = `Explain to a commercial borrower why the SBA requires the following document for underwriting: "${item}". Keep the explanation formal, strictly factual, concise, and under 3 sentences.`;
      const result = await fetchAutomatedContent(prompt, "You are a formal commercial banking system.");
      setExplanationText(result);
    } catch (err) {
      setExplanationText("System currently unable to retrieve definition. Consult standard SBA operational guidelines.");
    } finally {
      setIsExplaining(false);
    }
  };

  return (
    <div className="max-w-4xl mx-auto space-y-8">
      <AdUnit className="w-full h-[90px]" label="Top AdSpace" />

      <div className="border-b-2 border-slate-900 pb-4 mb-8">
        <h1 className="font-serif text-2xl font-bold text-slate-900 mb-2">Compliance & Document Matrix</h1>
        <p className="text-slate-600 text-sm font-sans">Generate legally-precise document requirements based on transaction architecture.</p>
      </div>

      <div className="grid sm:grid-cols-2 gap-8 bg-white border border-slate-200 rounded-lg p-8 shadow-sm">
        <div>
          <label className="block text-[10px] font-bold text-slate-600 uppercase tracking-widest mb-2">Transaction Classification</label>
          <select value={loanType} onChange={e => {setLoanType(e.target.value); setExplainingItem(null); setCheckedItems(new Set());}} className="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-900 focus:bg-white focus:border-slate-900 focus:ring-1 focus:ring-slate-900 outline-none">
            <option value="">Select Deal Type...</option>
            <option value="working_capital">Working Capital / Equipment</option>
            <option value="real_estate">Commercial Real Estate</option>
            <option value="acquisition">Business Acquisition</option>
          </select>
        </div>
        <div>
          <label className="block text-[10px] font-bold text-slate-600 uppercase tracking-widest mb-2">Corporate Structure</label>
          <select value={entity} onChange={e => {setEntity(e.target.value); setExplainingItem(null); setCheckedItems(new Set());}} className="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-sm text-slate-900 focus:bg-white focus:border-slate-900 focus:ring-1 focus:ring-slate-900 outline-none">
            <option value="">Select Entity...</option>
            <option value="LLC">LLC</option>
            <option value="Corp">S-Corp / C-Corp</option>
            <option value="SoleProp">Sole Proprietor</option>
          </select>
        </div>
      </div>

      {items.length > 0 && (
        <div className="bg-white border border-slate-200 rounded-lg overflow-hidden shadow-sm">
          <div className="bg-slate-50 border-b border-slate-200 px-8 py-6 flex justify-between items-center">
            <h3 className="font-serif text-[11px] font-bold text-slate-900 uppercase tracking-widest">Required Submissions</h3>
            <button onClick={()=>window.print()} className="text-[10px] font-bold text-slate-900 border border-slate-300 px-3 py-1.5 rounded-lg bg-white hover:bg-slate-50 transition-colors flex items-center gap-1.5 shadow-sm uppercase tracking-widest">
              <Download className="w-3.5 h-3.5" /> Export Matrix
            </button>
          </div>
          <div className="divide-y divide-slate-100">
            {items.map((item, i) => (
              <div key={i} className="flex flex-col">
                <div 
                  onClick={() => {
                    const next = new Set(checkedItems);
                    next.has(item) ? next.delete(item) : next.add(item);
                    setCheckedItems(next);
                  }}
                  className="px-8 py-6 flex items-center justify-between hover:bg-slate-50 transition-colors group cursor-pointer"
                >
                  <div className="flex items-center gap-4">
                    <div className={`w-5 h-5 rounded-sm border flex items-center justify-center flex-shrink-0 transition-colors ${checkedItems.has(item) ? 'bg-slate-900 border-slate-900' : 'bg-white border-slate-300 group-hover:border-slate-400'}`}>
                      {checkedItems.has(item) && <Check className="w-3.5 h-3.5 text-white" />}
                    </div>
                    <span className={`text-sm font-medium transition-all font-sans ${checkedItems.has(item) ? 'text-slate-400 line-through' : 'text-slate-800'}`}>{item}</span>
                  </div>
                  <button 
                    onClick={(e) => { e.stopPropagation(); handleExplain(item); }}
                    className="opacity-0 group-hover:opacity-100 transition-opacity text-[10px] uppercase tracking-widest font-bold text-slate-600 bg-white border border-slate-200 hover:border-slate-400 hover:text-slate-900 px-3 py-1.5 rounded-lg flex items-center gap-1.5 shadow-sm"
                  >
                    <MessageSquare className="w-3 h-3" /> Definition
                  </button>
                </div>
                
                {/* Explainer Block */}
                {explainingItem === item && (
                  <div className="px-16 py-6 bg-slate-50 border-t border-slate-100 text-sm">
                    {isExplaining ? (
                      <div className="flex items-center gap-3 text-slate-500 font-medium">
                        <Loader2 className="w-4 h-4 animate-spin text-slate-400" />
                        Processing federal definition...
                      </div>
                    ) : (
                      <div className="text-slate-700 leading-relaxed text-sm bg-white p-6 border border-slate-200 rounded-lg shadow-sm font-sans">
                        {explanationText}
                      </div>
                    )}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}
      
      <AdUnit className="w-full h-[90px]" label="Bottom Placement" />
    </div>
  );
}

