function Screener() {
  const [current, setCurrent] = useState(0);
  const [answers, setAnswers] = useState({});
  const [result, setResult] = useState(null);
  const [selected, setSelected] = useState("");

  const q = SCREENER_QUESTIONS[current];
  const progress = (current / SCREENER_QUESTIONS.length) * 100;

  const handleNext = () => {
    if (!selected) return;
    const newAnswers = { ...answers, [q.id]: selected };
    setAnswers(newAnswers);
    setSelected("");
    if (current + 1 >= SCREENER_QUESTIONS.length) {
      let reds = 0, yellows = 0;
      SCREENER_QUESTIONS.forEach(question => {
        const opt = question.options.find(o => o.value === newAnswers[question.id]);
        if (opt?.flag === 'red') reds++;
        if (opt?.flag === 'yellow') yellows++;
      });
      setResult(reds === 0 && yellows === 0 ? 'likely' : reds > 0 ? 'disqualified' : 'conditional');
    } else {
      setCurrent(c => c + 1);
    }
  };

  const restart = () => { setCurrent(0); setAnswers({}); setSelected(""); setResult(null); };

  if (result) {
    const isGood = result === 'likely';
    return (
      <div className="max-w-2xl mx-auto space-y-8">
        <AdUnit className="w-full h-24" label="Top Ad Placement" />
        
        <div className="bg-white border border-slate-200 rounded-lg p-12 shadow-sm text-center">
          <div className={`w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-8 border ${isGood ? 'bg-slate-50 border-emerald-600 text-emerald-600' : 'bg-slate-50 border-red-600 text-red-600'}`}>
            {isGood ? <CheckCircle2 className="w-8 h-8" /> : <AlertCircle className="w-8 h-8" />}
          </div>
          <h2 className="font-serif text-3xl font-bold text-slate-900 mb-6">
            {isGood ? "Eligibility Verified" : "Procedural Hard Stop Identified"}
          </h2>
          <p className="text-slate-600 mb-12 text-base leading-relaxed font-sans max-w-lg mx-auto">
            {isGood 
              ? "This application parameters satisfy foundational SBA 50 10 7 credit requirements. You may proceed to structuring and full document collection." 
              : "This file contains criteria that violate standard SBA operating procedures. Consider alternative commercial financing."}
          </p>
          <button onClick={restart} className="text-sm font-bold text-slate-900 bg-white border border-slate-300 hover:bg-slate-50 px-8 py-4 rounded-lg transition-colors shadow-sm">
            Process New Inquiry
          </button>
        </div>
      </div>
    );
  }

  return (
    <div className="max-w-2xl mx-auto space-y-8">
      <AdUnit className="w-full h-24" label="Top Ad Placement" />

      <div>
        <div className="flex items-center justify-between text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-4">
          <span>Eligibility Engine</span>
          <span>Phase {current + 1} of {SCREENER_QUESTIONS.length}</span>
        </div>
        <div className="w-full bg-slate-200 rounded-full h-2 overflow-hidden">
          <div className="bg-slate-900 h-full transition-all duration-500 ease-out" style={{ width: `${progress}%` }} />
        </div>
      </div>

      <div className="bg-white border border-slate-200 rounded-lg p-12 shadow-sm">
        <h2 className="font-serif text-2xl font-bold text-slate-900 mb-8 leading-snug">{q.q}</h2>
        {q.hint && (
          <div className="flex gap-4 bg-slate-50 border border-slate-200 p-4 mb-8 text-sm text-slate-600 font-medium rounded-lg items-start">
            <Info className="w-5 h-5 text-slate-400 shrink-0" />
            <p>{q.hint}</p>
          </div>
        )}

        <div className="border border-slate-200 rounded-lg overflow-hidden mb-8">
          {q.options.map((opt, idx) => (
            <button
              key={opt.value}
              onClick={() => setSelected(opt.value)}
              className={`w-full text-left px-6 py-5 border-b border-slate-200 last:border-0 transition-colors flex items-center gap-4 text-base font-medium
                ${selected === opt.value
                  ? "bg-slate-50 text-slate-900"
                  : "bg-white text-slate-600 hover:bg-slate-50"
                }`}
            >
              <div className={`w-4 h-4 rounded-full border flex items-center justify-center shrink-0 ${selected === opt.value ? 'border-slate-900' : 'border-slate-300'}`}>
                {selected === opt.value && <div className="w-2 h-2 rounded-full bg-slate-900" />}
              </div>
              {opt.label}
            </button>
          ))}
        </div>

        <div className="flex justify-between items-center pt-8 border-t border-slate-200">
          <button
            onClick={() => { if (current > 0) { setCurrent(c => c - 1); setSelected(answers[SCREENER_QUESTIONS[current - 1].id] || ""); } }}
            disabled={current === 0}
            className="text-sm font-bold text-slate-500 hover:text-slate-900 disabled:opacity-0 transition-colors px-4 py-2"
          >
            Previous
          </button>
          <button
            onClick={handleNext}
            disabled={!selected}
            className="bg-slate-900 text-white hover:bg-slate-800 disabled:opacity-50 font-bold px-8 py-4 rounded-lg transition-colors flex items-center gap-2 shadow-sm text-sm"
          >
            {current + 1 === SCREENER_QUESTIONS.length ? "Analyze Matrix" : "Continue Process"}
            <ArrowRight className="w-4 h-4" />
          </button>
        </div>
      </div>
      
      <AdUnit className="w-full h-24" label="Bottom Ad Placement" />
    </div>
  );
}

