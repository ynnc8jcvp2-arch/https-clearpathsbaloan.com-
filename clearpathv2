function pmt(rate, nper, pv) {
  if (rate === 0) return pv / nper;
  return (rate * pv * Math.pow(1 + rate, nper)) / (Math.pow(1 + rate, nper) - 1);
}

function CalculatorPitch() {
  const [amount, setAmount] = useState("450000");
  const [rateStr, setRateStr] = useState("10.5");
  const [years, setYears] = useState("10");
  const [prog, setProg] = useState("7a_10");
  
  // Terminal State
  const [rawNotes, setRawNotes] = useState("");
  const [isParsingNotes, setIsParsingNotes] = useState(false);
  const [businessScenario, setBusinessScenario] = useState("");
  const [generatingPitch, setGeneratingPitch] = useState(false);
  const [brokerEmail, setBrokerEmail] = useState("");
  const [errorMsg, setErrorMsg] = useState(null);
  const [copiedCell, setCopiedCell] = useState(null);
  
  // FY 2026 Waiver State
  const [isManufacturer, setIsManufacturer] = useState(false);

  // Calculations
  const principal = parseFloat(amount.replace(/,/g, "")) || 0;
  const annualRate = parseFloat(rateStr) / 100 || 0;
  const n = parseInt(years) * 12;
  const mr = annualRate / 12;
  const monthly = useMemo(() => principal > 0 && n > 0 ? pmt(mr, n, principal) : 0, [principal, mr, n]);
  
  const totalRepaid = monthly * n;
  const totalInterest = totalRepaid - principal;
  const principalPct = totalRepaid > 0 ? (principal / totalRepaid) * 100 : 0;
  const interestPct = totalRepaid > 0 ? (totalInterest / totalRepaid) * 100 : 0;

  // High Finance: SBA Guaranty Fee Estimation Logic (Blended proxies for broker estimates)
  const estimatedSBAFee = useMemo(() => {
    if (prog.includes('7a')) return principal * 0.0275; // Blended 2.75% avg 7(a) fee
    if (prog === '504') return principal * 0.025; // Blended 2.5% CDC/Participation fee
    if (prog === 'express') return principal * 0.02; // Blended 2.0% Express fee
    return principal * 0.025;
  }, [principal, prog]);
  
  const finalSBAFee = isManufacturer ? 0 : estimatedSBAFee;
  const feeSavings = estimatedSBAFee - finalSBAFee;

  const fmt = (v) => v.toLocaleString("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 });
  const fmt2 = (v) => v.toLocaleString("en-US", { style: "currency", currency: "USD", minimumFractionDigits: 2, maximumFractionDigits: 2 });

  const handleCopyCell = (text, id) => {
    try {
      // Bulletproof iframe fallback for copy-to-clipboard
      const textArea = document.createElement("textarea");
      textArea.value = text;
      // Prevent scrolling to bottom of page
      textArea.style.top = "0";
      textArea.style.left = "0";
      textArea.style.position = "fixed";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      
      setCopiedCell(id);
      setTimeout(() => setCopiedCell(null), 1500);
    } catch (err) {
      console.error('Fallback: Oops, unable to copy', err);
    }
  };

  const handleExportCSV = () => {
    let csv = "Month,Payment,Principal,Interest,Balance\n";
    let bal = principal;
    for (let i = 1; i <= n; i++) {
      const int = bal * mr;
      const pri = monthly - int;
      bal = Math.max(0, bal - pri);
      csv += `${i},${monthly.toFixed(2)},${pri.toFixed(2)},${int.toFixed(2)},${bal.toFixed(2)}\n`;
    }
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement("a");
    link.href = URL.createObjectURL(blob);
    link.download = `Amortization_Schedule_${principal}.csv`;
    link.click();
  };

  const handleCopyData = () => {
    let tsv = "Month\tPayment\tPrincipal\tInterest\tBalance\n";
    let bal = principal;
    for (let i = 1; i <= n; i++) {
      const int = bal * mr;
      const pri = monthly - int;
      bal = Math.max(0, bal - pri);
      tsv += `${i}\t${monthly.toFixed(2)}\t${pri.toFixed(2)}\t${int.toFixed(2)}\t${bal.toFixed(2)}\n`;
    }
    
    try {
      // Bulletproof iframe fallback for bulk data copy
      const textArea = document.createElement("textarea");
      textArea.value = tsv;
      textArea.style.top = "0";
      textArea.style.left = "0";
      textArea.style.position = "fixed";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      
      setCopiedCell('all');
      setTimeout(() => setCopiedCell(null), 2000);
    } catch (err) {
      console.error('Fallback: Oops, unable to copy', err);
    }
  };

  const handleParseNotes = async () => {
    if (!rawNotes.trim()) return;
    setIsParsingNotes(true);
    setErrorMsg(null);

    const systemPrompt = "You are a commercial loan assistant executing a data extraction protocol. Extract parameters from the broker's notes. Return JSON only.";
    const userPrompt = `Extract commercial loan parameters from the following unformatted text:
    Notes: "${rawNotes}"`;

    const schema = {
      type: "OBJECT",
      properties: {
        amount: { type: "STRING", description: "Loan amount as a plain number string without commas or $, e.g. '500000'." },
        program: { type: "STRING", description: "Exact match required: '7a_25', '7a_10', 'express', or '504'." },
        years: { type: "STRING", description: "Term in years, integer string." },
        assessment: { type: "STRING", description: "Formal 2-3 sentence strategic broker assessment." }
      },
      required: ["amount", "program", "years", "assessment"]
    };

    try {
      const data = await fetchAutomatedContent(userPrompt, systemPrompt, schema);
      if (data.amount) setAmount(Number(data.amount).toLocaleString());
      if (data.program && PROGRAMS.some(p => p.id === data.program)) setProg(data.program);
      if (data.years) setYears(data.years);
